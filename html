<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Planificateur EPS - Course de Durée</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>🏃 Planificateur de Course</h1>
            <p>Calcul des allures et objectifs VMA</p>
        </header>

        <section class="card">
            <div class="input-group">
                <label for="vmaInput">VMA de l'élève (km/h)</label>
                <input type="number" id="vmaInput" placeholder="Ex: 13.5" step="0.1">
            </div>

            <div class="input-group">
                <label for="intensiteInput">Intensité souhaitée (%)</label>
                <input type="number" id="intensiteInput" value="80">
            </div>

            <button onclick="calculerPlan()">Générer le plan</button>

            <div id="resultBox" class="results" style="display:none;">
                <div class="res-card">
                    <small>Vitesse Cible</small>
                    <div id="vitesseCible" class="value">--</div>
                    <span>km/h</span>
                </div>
                <div class="res-card">
                    <small>Allure</small>
                    <div id="allureCible" class="value">--</div>
                    <span>min/km</span>
                </div>
            </div>
        </section>

        <section class="card table-card">
            <h3>Historique des élèves</h3>
            <table id="eleveTable">
                <thead>
                    <tr>
                        <th>VMA</th>
                        <th>%</th>
                        <th>Vitesse</th>
                        <th>Allure</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    </tbody>
            </table>
        </section>
    </div>
    <script src="script.js"></script>
</body>
</html>
